{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_WEBSITE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_ANON_KEY",
    "N8N_WEBHOOK_SURVEY_ANALYSIS_URL",
    "N8N_WEBHOOK_BOOKING_URL",
    "N8N_WEBHOOK_FORM_CONFIRM_EMAIL_URL",
    "HOST_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_CALLBACK_PATH",
    "GOOGLE_MOCK_MODE",
    "OPENAI_API_KEY",
    "WORKFLOW_TRIGGER_SECRET",
    "N8N_WORKFLOW_ORCHESTRATOR_URL",
    "SUPABASE_URL",
    "BUCKET_ACCESS_KEY",
    "BUCKET_SECRET_KEY"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
